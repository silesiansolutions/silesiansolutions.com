{
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.7.0",
    "scripts": {
        "build": "astro build && node scripts/ci/copy-404-route.mjs",
        "develop": "astro dev",
        "start": "astro dev",
        "preview": "astro preview",
        "clean": "rm -rf dist .astro",
        "test": "node --test scripts/ci/*.test.mjs",
        "lint": "eslint . --max-warnings 0",
        "format": "prettier --write \"**/*.{astro,js,jsx,json,yml,yaml,css,ts,tsx,md,mdx,mjs}\"",
        "format:check": "prettier --check \"**/*.{astro,js,jsx,json,yml,yaml,css,ts,tsx,md,mdx,mjs}\"",
        "type-check": "astro check",
        "check:build": "node scripts/ci/check-build-output.mjs",
        "check:structured-data": "node scripts/ci/check-structured-data.mjs",
        "doctor:search-quality": "search-quality-kit doctor --config search-quality.config.ts",
        "check:search-quality": "search-quality-kit verify",
        "contract:search-quality": "search-quality-kit contract --config search-quality.config.ts --output search-quality-contract.json",
        "handoff:search-quality": "search-quality-kit report search-quality-report.json --format handoff --output search-quality-handoff.md"
    },
    "dependencies": {
        "@astrojs/react": "^6.0.1",
        "@astrojs/sitemap": "^3.7.3",
        "@fontsource/roboto": "^5.2.10",
        "js-cookie": "^3.0.8",
        "marked": "^18.0.6",
        "mini-svg-data-uri": "^1.4.4",
        "normalize.css": "^8.0.1",
        "prismjs": "^1.30.0",
        "schema-dts": "^2.0.0",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@eslint/js": "^10.0.1",
        "@silesiansolutions/search-quality-kit": "0.10.0",
        "@types/js-cookie": "^3.0.6",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "astro": "^7.0.7",
        "eslint": "^10.6.0",
        "eslint-plugin-astro": "^2.1.1",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.5",
        "prettier-plugin-astro": "^0.14.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.63.0",
        "vite-imagetools": "^10.0.1"
    },
    "engines": {
        "node": ">=24.11.0"
    },
    "lint-staged": {
        "*.+(ts|tsx)": [
            "pnpm lint"
        ],
        "*.+(js|jsx|json|yml|yaml|css|less|scss|ts|tsx|md|graphql|mdx)": [
            "pnpm format"
        ]
    }
}
