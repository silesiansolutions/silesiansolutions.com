---
import BaseLayout from '../layouts/BaseLayout.astro';
import InformationClausePage from '../../src/pages/klauzula-informacyjna.jsx';
import { getPageSeoData } from '../../src/utils/seoHelpers';

const seo = getPageSeoData('terms');
---

<BaseLayout
    title={seo.seoTitle}
    description={seo.description}
    noIndex
    breadcrumbs={[
        { name: 'Strona główna', path: '/' },
        { name: seo.title, path: '/klauzula-informacyjna/' },
    ]}
>
    <InformationClausePage client:load />
</BaseLayout>
