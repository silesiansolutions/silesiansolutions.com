---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectsPage from '../../../src/pages/realizacje.jsx';
import { getPageSeoData } from '../../../src/utils/seoHelpers';

const seo = getPageSeoData('projects');
---

<BaseLayout
    title={seo.seoTitle}
    description={seo.description}
    pageType="CollectionPage"
    breadcrumbs={[
        { name: 'Strona główna', path: '/' },
        { name: seo.title, path: '/realizacje/' },
    ]}
>
    <ProjectsPage client:load />
</BaseLayout>
