---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactPage from '../../../src/pages/kontakt/index.jsx';
import { getPageSeoData } from '../../../src/utils/seoHelpers';

const seo = getPageSeoData('contact');
---

<BaseLayout
    title={seo.seoTitle}
    description={seo.description}
    pageType="ContactPage"
    breadcrumbs={[
        { name: 'Strona główna', path: '/' },
        { name: seo.title, path: '/kontakt/' },
    ]}
>
    <ContactPage client:load />
</BaseLayout>
